# ========== SERVER CONFIGURATION ==========
PORT=8000

# ========== DATABASE ==========
# MongoDB connection string
# Format: mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGO_URI="mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority"

# ========== EMAIL CONFIGURATION (SMTP) ==========
# Service name (usually your email provider)
SMTP_SERVICE="your-email-service"
# Your email address for sending emails
SMTP_USER="your-email@example.com"
# SMTP password or app-specific password
SMTP_PASS="your-smtp-password"

# ========== IMAGE UPLOAD (CLOUDINARY) ==========
# Get these from your Cloudinary dashboard
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# ========== AUTHENTICATION (JWT) ==========
# JWT expiration time (e.g., 10d for 10 days, 7d for 7 days)
JWT_EXPIRE="10d"
# Secret key for signing JWT tokens (use a strong random string)
JWT_SECRET="your-secure-jwt-secret-key"

# ========== PAYMENT GATEWAY (RAZORPAY) ==========
# Get these from your Razorpay dashboard
RAZORPAY_KEY_ID="your-razorpay-key-id"
RAZORPAY_KEY_SECRET="your-razorpay-key-secret"

# ========== AI/LLM CONFIGURATION ==========
# OpenAI API key for roadmap generation
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY="your-openai-api-key"

# ========== FRONTEND & CORS ==========
# Frontend URL (for redirects and links)
FRONTEND_URL="http://localhost:5173"
# Allowed origins for CORS (comma-separated if multiple)
ALLOWED_ORIGINS="http://localhost:5173,https://yourdomain.com"

# ========== GOOGLE OAUTH ==========
# Get these from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id-here"
